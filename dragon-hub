<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#101848">
<title>Jimmy's Quest Hub</title>
<style>
:root{
  --bg:#101848;--bg2:#0c1240;--border-o:#f8f0e0;--border-i:#c8b878;--border-d:#485090;
  --text:#f8f8f8;--dim:#a0a8d0;--gold:#f8d848;--blue:#68c0f8;--green:#68e868;--red:#f87070;
  --gg:rgba(248,216,72,0.12);--font:'Courier New','Courier',monospace;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{min-height:100vh;min-height:100dvh;background:var(--bg);color:var(--text);font-family:var(--font);max-width:480px;margin:0 auto;padding:0 0 40px;-webkit-font-smoothing:antialiased}

.dq{position:relative;background:linear-gradient(180deg,#182058,#101848);border:3px solid var(--border-o);border-radius:10px;padding:14px;box-shadow:inset 0 0 0 2px var(--border-d),0 4px 16px rgba(0,0,0,.3)}
.dq::before{content:'';position:absolute;inset:2px;border:1px solid var(--border-i);border-radius:7px;pointer-events:none}

/* Slime */
.slime-wrap{display:flex;justify-content:center;padding:20px 0 4px}
.slime-container{width:80px;height:80px;animation:bounce 2.5s ease-in-out infinite}
.slime-container svg{width:100%;height:100%}
@keyframes bounce{0%,100%{transform:translateY(0) scaleY(1) scaleX(1)}30%{transform:translateY(-8px) scaleY(1.05) scaleX(.96)}50%{transform:translateY(0) scaleY(.93) scaleX(1.05)}70%{transform:translateY(-3px) scaleY(1.02) scaleX(.99)}}

/* Header */
.header{text-align:center;padding:4px 16px 16px}
.header h1{font-size:22px;color:var(--gold);letter-spacing:3px;text-shadow:0 0 14px rgba(248,216,72,.25);text-transform:uppercase}
.header .sub{font-size:11px;color:var(--dim);margin-top:4px}

/* App grid */
.app-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;padding:0 16px 16px}

.app-card{padding:16px 12px;text-align:center;text-decoration:none;color:var(--text);transition:all .15s;cursor:pointer;display:block}
.app-card:active{transform:scale(.97)}
.ac-icon{font-size:32px;margin-bottom:6px}
.ac-name{font-size:12px;font-weight:bold;color:var(--gold);letter-spacing:.5px}
.ac-desc{font-size:9px;color:var(--dim);margin-top:3px;line-height:1.4}

/* Save section */
.save-section{padding:0 16px 12px}
.save-title{font-size:12px;color:var(--gold);text-transform:uppercase;letter-spacing:1px;text-align:center;margin-bottom:10px}

.save-btns{display:flex;flex-direction:column;gap:8px}

.save-btn{width:100%;padding:14px;border:2px solid var(--border-o);border-radius:6px;background:linear-gradient(180deg,#283880,#182058);color:var(--gold);font-family:var(--font);font-size:13px;font-weight:bold;cursor:pointer;text-transform:uppercase;letter-spacing:.5px;transition:all .2s;box-shadow:0 0 12px rgba(248,216,72,.06)}
.save-btn:active{transform:scale(.97)}

.save-btn.secondary{background:linear-gradient(180deg,#182058,#101848);border-color:var(--border-d);color:var(--dim);box-shadow:none}

.save-info{font-size:10px;color:var(--dim);text-align:center;margin-top:10px;line-height:1.5}

/* Last backup */
.last-backup{text-align:center;padding:0 16px 12px}
.lb-text{font-size:10px;color:var(--dim)}
.lb-date{font-size:11px;color:var(--green);font-weight:bold}

/* Status */
.status-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;padding:0 16px 16px}
.status-card{text-align:center;padding:8px 4px;background:rgba(0,0,0,.15);border:1px solid var(--border-d);border-radius:6px}
.sc-val{font-size:14px;font-weight:bold;color:var(--gold)}
.sc-label{font-size:8px;color:var(--dim);text-transform:uppercase;letter-spacing:.3px;margin-top:1px}

/* Toast */
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(16px);background:linear-gradient(180deg,#182058,#101848);border:2px solid var(--border-o);color:var(--gold);padding:8px 18px;border-radius:4px;font-family:var(--font);font-size:12px;font-weight:bold;z-index:999;opacity:0;transition:all .3s;pointer-events:none}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* Overlay */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:100;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .2s}
.overlay.open{opacity:1;pointer-events:auto}
.ov-box{max-width:320px;width:100%;text-align:center;padding:20px}
.ov-icon{font-size:40px;margin-bottom:10px}
.ov-text{font-size:14px;color:var(--text);line-height:1.6;margin-bottom:14px}
.ov-text .hl{color:var(--gold)}
.ov-text .gr{color:var(--green)}
.ov-btn{padding:12px 28px;border:2px solid var(--border-o);border-radius:4px;background:linear-gradient(180deg,#283880,#182058);color:var(--gold);font-family:var(--font);font-size:13px;font-weight:bold;cursor:pointer;text-transform:uppercase}
</style>
</head>
<body>

<!-- Slime -->
<div class="slime-wrap">
  <div class="slime-container">
    <svg viewBox="0 0 100 100">
      <defs>
        <radialGradient id="sg" cx="40%" cy="35%" r="60%">
          <stop offset="0%" stop-color="#6DD8FF"/>
          <stop offset="40%" stop-color="#2EA8E0"/>
          <stop offset="75%" stop-color="#1B7CB8"/>
          <stop offset="100%" stop-color="#145F8A"/>
        </radialGradient>
      </defs>
      <path d="M50 6C50 6,42 18,30 32C18 46,10 58,10 68C10 82,22 95,50 95C78 95,90 82,90 68C90 58,82 46,70 32C58 18,50 6,50 6Z" fill="url(#sg)" stroke="#0E5A80" stroke-width="1"/>
      <ellipse cx="38" cy="62" rx="7.5" ry="8.5" fill="#fff"/>
      <ellipse cx="39.5" cy="62.5" rx="3.8" ry="4.5" fill="#1A1A2E"/>
      <ellipse cx="40.5" cy="61" rx="1.5" ry="1.8" fill="#fff"/>
      <ellipse cx="62" cy="62" rx="7.5" ry="8.5" fill="#fff"/>
      <ellipse cx="63.5" cy="62.5" rx="3.8" ry="4.5" fill="#1A1A2E"/>
      <ellipse cx="64.5" cy="61" rx="1.5" ry="1.8" fill="#fff"/>
      <path d="M38 76Q42 83,50 84Q58 83,62 76" fill="none" stroke="#0E4A6A" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </div>
</div>

<!-- Header -->
<div class="header">
  <h1>Quest Hub</h1>
  <div class="sub">Jimmy's Adventure Toolkit</div>
</div>

<!-- Quick stats -->
<div class="status-grid">
  <div class="status-card">
    <div class="sc-val" id="statLevel">—</div>
    <div class="sc-label">Hero Level</div>
  </div>
  <div class="status-card">
    <div class="sc-val" id="statGold">—</div>
    <div class="sc-label">Gold</div>
  </div>
  <div class="status-card">
    <div class="sc-val" id="statItems">—</div>
    <div class="sc-label">Collection</div>
  </div>
</div>

<!-- App Grid -->
<div class="app-grid">
  <a class="app-card dq" href="med-tracker.html">
    <div class="ac-icon">💊</div>
    <div class="ac-name">Med Tracker</div>
    <div class="ac-desc">Dose, mood & side effects</div>
  </a>
  <a class="app-card dq" href="save-it.html">
    <div class="ac-icon">🐉</div>
    <div class="ac-name">Save It</div>
    <div class="ac-desc">Impulse spending guard</div>
  </a>
  <a class="app-card dq" href="adventure-log.html">
    <div class="ac-icon">📜</div>
    <div class="ac-name">Adventure Log</div>
    <div class="ac-desc">Journal thy thoughts</div>
  </a>
  <a class="app-card dq" href="gratitude-chest.html">
    <div class="ac-icon">✨</div>
    <div class="ac-name">Gratitude Chest</div>
    <div class="ac-desc">One good thing a day</div>
  </a>
  <a class="app-card dq" href="quest-board.html">
    <div class="ac-icon">⚔️</div>
    <div class="ac-name">Quest Board</div>
    <div class="ac-desc">Daily quests & loot</div>
  </a>
  <a class="app-card dq" href="slime-dressup.html">
    <div class="ac-icon">👑</div>
    <div class="ac-name">Slime Dress-Up</div>
    <div class="ac-desc">Equip thy treasures</div>
  </a>
</div>

<!-- Save Section -->
<div class="save-section">
  <div class="save-title">🏰 Save Point</div>
  <div class="last-backup" id="lastBackup"></div>
  <div class="save-btns">
    <button class="save-btn" onclick="backupAll()">Save Adventure (Backup All)</button>
    <button class="save-btn secondary" onclick="document.getElementById('restoreFile').click()">Restore Adventure</button>
    <input type="file" id="restoreFile" accept=".json" style="display:none" onchange="restoreAll(event)">
  </div>
  <div class="save-info">One file. All six apps.<br>Everything saved. Everything restored.</div>
</div>

<!-- Success overlay -->
<div class="overlay" id="successOv">
  <div class="ov-box dq">
    <div class="ov-icon" id="ovIcon">🏰</div>
    <div class="ov-text" id="ovText"></div>
    <button class="ov-btn" onclick="closeOv()">Continue</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// All localStorage keys used by the apps
const APP_KEYS = [
  { key: 'med-tracker-entries', name: 'Med Tracker' },
  { key: 'save-it-entries', name: 'Save It' },
  { key: 'adventure-log-entries', name: 'Adventure Log' },
  { key: 'gratitude-chest-entries', name: 'Gratitude Chest' },
  { key: 'heros-quest-board', name: 'Quest Board' },
  { key: 'slime-dressup-equip', name: 'Slime Dress-Up' },
];

const BACKUP_META_KEY = 'quest-hub-last-backup';

function init() {
  updateStats();
  showLastBackup();
}

function updateStats() {
  // Read quest board data for hero stats
  try {
    const raw = localStorage.getItem('heros-quest-board');
    if (raw) {
      const g = JSON.parse(raw);
      document.getElementById('statLevel').textContent = 'Lv.' + (g.level || 1);
      document.getElementById('statGold').textContent = (g.gold || 0) + ' G';
      document.getElementById('statItems').textContent = (g.owned ? g.owned.length : 0);
    } else {
      document.getElementById('statLevel').textContent = '—';
      document.getElementById('statGold').textContent = '—';
      document.getElementById('statItems').textContent = '—';
    }
  } catch(e) {
    document.getElementById('statLevel').textContent = '—';
    document.getElementById('statGold').textContent = '—';
    document.getElementById('statItems').textContent = '—';
  }
}

function showLastBackup() {
  const el = document.getElementById('lastBackup');
  try {
    const meta = localStorage.getItem(BACKUP_META_KEY);
    if (meta) {
      const d = new Date(meta);
      const str = d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
      el.innerHTML = '<div class="lb-text">Last backup</div><div class="lb-date">' + str + '</div>';
    } else {
      el.innerHTML = '<div class="lb-text">No backups yet</div>';
    }
  } catch(e) {
    el.innerHTML = '<div class="lb-text">No backups yet</div>';
  }
}

// ═══ BACKUP ═══
function backupAll() {
  const backup = {
    _meta: {
      version: 1,
      date: new Date().toISOString(),
      app: 'quest-hub'
    }
  };

  let totalEntries = 0;
  APP_KEYS.forEach(app => {
    try {
      const raw = localStorage.getItem(app.key);
      if (raw) {
        backup[app.key] = JSON.parse(raw);
        totalEntries++;
      }
    } catch(e) {}
  });

  if (totalEntries === 0) {
    toast('No data to backup!');
    return;
  }

  const blob = new Blob([JSON.stringify(backup, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'quest-hub-backup.json';
  a.click();
  URL.revokeObjectURL(url);

  // Save backup timestamp
  localStorage.setItem(BACKUP_META_KEY, new Date().toISOString());
  showLastBackup();

  // Show success
  document.getElementById('ovIcon').textContent = '🏰';
  document.getElementById('ovText').innerHTML = '<span class="hl">Jimmy</span> saved the adventure!<br><br><span class="gr">' + totalEntries + ' app' + (totalEntries !== 1 ? 's' : '') + '</span> backed up to one file.';
  document.getElementById('successOv').classList.add('open');
}

// ═══ RESTORE ═══
function restoreAll(event) {
  const file = event.target.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const backup = JSON.parse(e.target.result);

      // Validate it's a quest hub backup
      if (!backup._meta || backup._meta.app !== 'quest-hub') {
        toast('Not a valid Quest Hub backup!');
        return;
      }

      let restored = 0;
      APP_KEYS.forEach(app => {
        if (backup[app.key]) {
          localStorage.setItem(app.key, JSON.stringify(backup[app.key]));
          restored++;
        }
      });

      if (restored === 0) {
        toast('Backup was empty!');
        return;
      }

      updateStats();

      // Show success
      const backupDate = new Date(backup._meta.date);
      const dateStr = backupDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });

      document.getElementById('ovIcon').textContent = '✨';
      document.getElementById('ovText').innerHTML = 'Adventure restored!<br><br><span class="gr">' + restored + ' app' + (restored !== 1 ? 's' : '') + '</span> loaded from backup.<br><span style="font-size:11px;color:var(--dim)">Backup from: ' + dateStr + '</span>';
      document.getElementById('successOv').classList.add('open');

    } catch(err) {
      toast('Restore failed — bad file');
    }
  };
  reader.readAsText(file);
  event.target.value = '';
}

function closeOv() { document.getElementById('successOv').classList.remove('open'); }
function toast(msg) { const t = document.getElementById('toast'); t.textContent = msg; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 2500); }

init();
</script>
</body>
</html>
