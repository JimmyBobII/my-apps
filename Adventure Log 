const SAVE_MESSAGES=[
'<span class="hl">Jimmy</span> recorded a new page in the Adventure Log!\n\nThy thoughts are preserved for the ages.',
'The quill glows with magical light!\n\n<span class="hl">Jimmy\'s</span> words have been inscribed in the sacred tome.',
'<span class="hl">Jimmy</span> rests at the inn and reflects on the journey.\n\nProgress has been <span class="gr">saved</span>!',
'A new chapter unfolds!\n\n<span class="hl">Jimmy\'s</span> adventure log grows ever stronger.',
'<span class="hl">Jimmy</span> gained insight from writing!\n\nSelf-awareness increased by <span class="gr">1</span>!',
'The pen is mightier than the sword!\n\n<span class="hl">Jimmy</span> recorded the day\'s battles.',
'The Goddess smiles upon thee.\n\nThy <span class="gr">adventure log</span> has been updated!',
'<span class="hl">Jimmy</span> faces the day with courage.\n\nEntry recorded. The quest continues!',
'The party rests by the campfire.\n\n<span class="hl">Jimmy\'s</span> thoughts join the flickering embers.',
'<span class="hl">Jimmy</span> opens the sacred tome and writes.\n\nAnother day survived. Another page <span class="gr">filled</span>.',
];

const STORAGE_KEY='adventure-log-entries';
let entries=[];
let state={editingId:null};
let pendingDeleteId=null;

function spawnCreature(){const c=CREATURES[Math.floor(Math.random()*CREATURES.length)];document.getElementById('creatureWrap').innerHTML=c.svg+'<div class="slime-shadow"></div>';document.getElementById('creatureName').textContent=c.name;}
function newWisdom(){const q=DQ_QUOTES[Math.floor(Math.random()*DQ_QUOTES.length)];document.getElementById('wisdomText').textContent=q.q;document.getElementById('wisdomSource').textContent='— '+q.src;}

function init(){
  try{const r=localStorage.getItem(STORAGE_KEY);if(r)entries=JSON.parse(r);}catch(e){}
  document.getElementById('dateText').textContent=new Date().toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long'});
  spawnCreature();newWisdom();updateUI();
}
function save(){localStorage.setItem(STORAGE_KEY,JSON.stringify(entries));}
function updateUI(){
  document.getElementById('entryCount').textContent=entries.length;
  document.getElementById('statEntries').textContent=entries.length;
  let streak=0;const today=new Date();
  for(let i=0;i<365;i++){const d=new Date(today);d.setDate(d.getDate()-i);if(entries.some(e=>new Date(e.date).toDateString()===d.toDateString()))streak++;else break;}
  document.getElementById('statStreak').textContent=streak;
  document.getElementById('statStreak').style.color=streak>=7?'var(--green)':'var(--text-gold)';
  const words=entries.reduce((s,e)=>s+(e.text||'').split(/\s+/).filter(w=>w).length,0);
  document.getElementById('statWords').textContent=words>999?(words/1000).toFixed(1)+'k':words;
  document.getElementById('submitBtn').textContent=state.editingId?'Save Changes':'Record in the Adventure Log';
  const c=document.getElementById('cancelBtn');if(state.editingId)c.classList.add('visible');else c.classList.remove('visible');
}
function resetForm(){state={editingId:null};document.getElementById('journalText').value='';updateUI();}
function handleSubmit(){
  const text=document.getElementById('journalText').value.trim();
  if(!text){showToast('Write something first, hero!');return;}
  const existing=state.editingId?entries.find(e=>e.id===state.editingId):null;
  const entry={id:state.editingId||Date.now(),date:existing?existing.date:new Date().toISOString(),text};
  if(state.editingId)entries=entries.map(e=>e.id===state.editingId?entry:e);
  else entries.push(entry);
  entries.sort((a,b)=>new Date(a.date)-new Date(b.date));save();
  const wasEditing=!!state.editingId;resetForm();updateUI();
  if(wasEditing){showToast('Entry updated!');showView('log');}
  else{
    const msg=SAVE_MESSAGES[Math.floor(Math.random()*SAVE_MESSAGES.length)];
    const q=DQ_QUOTES[Math.floor(Math.random()*DQ_QUOTES.length)];
    document.getElementById('successText').innerHTML=msg.replace(/\n/g,'<br>');
    document.getElementById('successQuote').innerHTML='"'+q.q+'"<br>— '+q.src;
    document.getElementById('successOverlay').classList.add('open');
  }
}
function cancelEdit(){resetForm();}
function editEntry(id){const e=entries.find(x=>x.id===id);if(!e)return;state.editingId=e.id;document.getElementById('journalText').value=e.text||'';showView('write');updateUI();}
function requestDelete(id){pendingDeleteId=id;document.getElementById('delOverlay').classList.add('open');document.getElementById('delConfirmBtn').onclick=()=>{entries=entries.filter(e=>e.id!==pendingDeleteId);save();closeDelete();renderLog();updateUI();showToast('Entry erased');};}
function closeDelete(){document.getElementById('delOverlay').classList.remove('open');pendingDeleteId=null;}
function closeSuccess(){document.getElementById('successOverlay').classList.remove('open');}
function showView(v){
  ['writeView','logView'].forEach(id=>document.getElementById(id).classList.add('hidden'));
  ['navWrite','navLog'].forEach(id=>document.getElementById(id).classList.remove('active'));
  if(v==='write'){document.getElementById('writeView').classList.remove('hidden');document.getElementById('navWrite').classList.add('active');}
  else{document.getElementById('logView').classList.remove('hidden');document.getElementById('navLog').classList.add('active');renderLog();}
}
function renderLog(){
  const wrap=document.getElementById('logList');
  const query=(document.getElementById('searchInput').value||'').toLowerCase().trim();
  let filtered=[...entries].reverse();
  if(query)filtered=filtered.filter(e=>(e.text||'').toLowerCase().includes(query));
  if(!filtered.length){wrap.innerHTML=`<div class="empty-state"><div class="empty-icon">📜</div><div class="empty-text">${query?'No matching entries':'The adventure log is empty'}</div><div class="empty-sub">${query?'Try different words':'Begin thy tale, hero'}</div></div>`;return;}
  let html='';
  filtered.forEach((entry,i)=>{
    const dateStr=new Date(entry.date).toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
    const num=entries.indexOf(entry)+1;
    const preview=(entry.text||'').length>200?entry.text.slice(0,200)+'...':entry.text;
    html+=`<div class="log-card dq-window" style="animation-delay:${i*0.04}s"><div class="lc-top"><div class="lc-entry-num">Entry #${num}</div><div class="lc-date">${dateStr}</div></div><div class="lc-body">${escHtml(preview)}</div><div class="lc-actions"><button class="lc-btn" onclick="editEntry(${entry.id})">✏️ Edit</button><button class="lc-btn" onclick="requestDelete(${entry.id})">Erase</button></div></div>`;
  });
  wrap.innerHTML=html;
}
function exportJSON(){if(!entries.length){showToast('Nothing to export');return;}dl(JSON.stringify(entries,null,2),'adventure-log-'+iso()+'.json','application/json');showToast('JSON exported!');}
function exportTXT(){if(!entries.length){showToast('Nothing to export');return;}const txt=entries.map(e=>{const d=new Date(e.date).toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'});return'═══ '+d+' ═══\n\n'+e.text+'\n';}).join('\n\n');dl(txt,'adventure-log-'+iso()+'.txt','text/plain');showToast('Text exported!');}
function dl(c,n,t){const b=new Blob([c],{type:t});const u=URL.createObjectURL(b);const a=document.createElement('a');a.href=u;a.download=n;a.click();URL.revokeObjectURL(u);}
function importData(event){const file=event.target.files[0];if(!file)return;const reader=new FileReader();reader.onload=function(e){try{const imp=JSON.parse(e.target.result);if(!Array.isArray(imp))throw 0;entries=imp;save();updateUI();showToast(entries.length+' entries loaded!');}catch(err){showToast('Import failed');}};reader.readAsText(file);event.target.value='';}
function escHtml(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML;}
function iso(){return new Date().toISOString().slice(0,10);}
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2500);}
init();
</script>
