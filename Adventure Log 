<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#0a0818">
<title>Adventure Log</title>
<style>
:root {
  --bg: #0a0818;
  --bg-window: #0d0a1e;
  --border-outer: #f0e0a0;
  --border-inner: #b89840;
  --border-dark: #584810;
  --text: #f0f0f0;
  --text-dim: #8888aa;
  --text-gold: #f0d860;
  --text-blue: #58a8f8;
  --gold-glow: rgba(240, 216, 96, 0.15);
  --green: #58d858;
  --red: #f06868;
  --red-glow: rgba(240, 104, 104, 0.12);
  --font: 'Courier New', 'Courier', monospace;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body { min-height: 100vh; min-height: 100dvh; background: var(--bg); color: var(--text); font-family: var(--font); max-width: 480px; margin: 0 auto; padding: 0 0 100px 0; -webkit-font-smoothing: antialiased; }
.dq-window { position: relative; background: var(--bg-window); border: 3px solid var(--border-outer); border-radius: 8px; padding: 16px; box-shadow: inset 0 0 0 2px var(--border-dark), 0 0 20px rgba(240,216,96,0.06); }
.dq-window::before { content: ''; position: absolute; inset: 2px; border: 1px solid var(--border-inner); border-radius: 5px; pointer-events: none; }
.slime-wrap { display: flex; flex-direction: column; align-items: center; padding: 16px 0 0; cursor: pointer; }
.slime-container { position: relative; width: 80px; height: 80px; animation: slimeBounce 2.5s ease-in-out infinite; }
@keyframes slimeBounce { 0%,100%{transform:translateY(0) scaleY(1) scaleX(1)} 30%{transform:translateY(-8px) scaleY(1.05) scaleX(0.96)} 50%{transform:translateY(0) scaleY(0.93) scaleX(1.05)} 70%{transform:translateY(-3px) scaleY(1.02) scaleX(0.99)} }
.slime-container svg { width: 100%; height: 100%; }
.slime-shadow { position: absolute; bottom: -6px; left: 50%; transform: translateX(-50%); width: 50px; height: 8px; background: radial-gradient(ellipse, rgba(0,0,0,0.3) 0%, transparent 70%); animation: shadowPulse 2.5s ease-in-out infinite; }
@keyframes shadowPulse { 0%,100%{transform:translateX(-50%) scaleX(1);opacity:.6} 30%{transform:translateX(-50%) scaleX(.7);opacity:.3} 50%{transform:translateX(-50%) scaleX(1.1);opacity:.7} }
.creature-name { font-size: 10px; font-weight: bold; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
.header { text-align: center; padding: 4px 16px 12px; }
.header h1 { font-size: 20px; color: var(--text-gold); letter-spacing: 2px; text-shadow: 0 0 10px rgba(240,216,96,0.3); text-transform: uppercase; }
.header .sub { font-size: 11px; color: var(--text-dim); margin-top: 2px; }
.stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; padding: 0 16px 4px; }
.stat-card { text-align: center; background: var(--bg-window); border: 2px solid var(--border-dark); border-radius: 6px; padding: 10px 4px; }
.stat-val { font-size: 20px; font-weight: bold; color: var(--text-gold); }
.stat-label { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }
.wisdom-box { margin: 0 16px 10px; padding: 12px; cursor: pointer; }
.wisdom-label { font-size: 9px; color: var(--text-blue); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
.wisdom-text { font-size: 12px; color: var(--text); line-height: 1.5; font-style: italic; }
.wisdom-source { font-size: 10px; color: var(--text-dim); margin-top: 6px; }
.wisdom-refresh { font-size: 9px; color: #404060; margin-top: 4px; }
.nav { display: flex; gap: 4px; padding: 12px 16px; }
.nav-btn { flex: 1; padding: 10px 4px; border: 2px solid var(--border-dark); border-radius: 4px; background: var(--bg-window); color: var(--text-dim); font-family: var(--font); font-size: 11px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 0.3px; transition: all 0.15s; }
.nav-btn.active { background: var(--gold-glow); border-color: var(--border-outer); color: var(--text-gold); box-shadow: 0 0 10px rgba(240,216,96,0.1); }
.nav-cnt { font-size: 9px; opacity: 0.7; }
.section { padding: 0 16px; }
.hidden { display: none !important; }
textarea { width: 100%; padding: 14px; border: 2px solid var(--border-inner); border-radius: 4px; background: #0d0a1e; color: var(--text); font-family: var(--font); font-size: 14px; outline: none; resize: vertical; line-height: 1.7; transition: border-color 0.2s; }
textarea:focus { border-color: var(--border-outer); }
textarea::placeholder { color: #404060; }
.label { display: block; font-size: 11px; color: var(--text-gold); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
.field { margin-bottom: 16px; }
.submit-btn { width: 100%; padding: 14px; border: 2px solid var(--border-outer); border-radius: 4px; background: linear-gradient(180deg, #2a2050, #1a1030); color: var(--text-gold); font-family: var(--font); font-size: 14px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; box-shadow: 0 0 16px rgba(240,216,96,0.08); transition: all 0.2s; }
.submit-btn:disabled { opacity: 0.3; cursor: not-allowed; box-shadow: none; }
.submit-btn:not(:disabled):active { transform: scale(0.97); }
.cancel-btn { width: 100%; padding: 10px; border: 1px solid var(--border-dark); border-radius: 4px; background: transparent; color: var(--text-dim); font-family: var(--font); font-size: 12px; cursor: pointer; margin-top: 8px; display: none; }
.cancel-btn.visible { display: block; }
.log-card { margin-bottom: 10px; padding: 14px; }
.lc-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
.lc-entry-num { font-size: 12px; font-weight: bold; color: var(--text-gold); }
.lc-date { font-size: 11px; color: var(--text-dim); }
.lc-body { font-size: 13px; color: var(--text); line-height: 1.7; white-space: pre-wrap; word-wrap: break-word; }
.lc-actions { display: flex; justify-content: flex-end; gap: 6px; margin-top: 10px; padding-top: 8px; border-top: 1px solid #1a1830; }
.lc-btn { padding: 4px 10px; border: 1px solid var(--border-dark); border-radius: 3px; background: transparent; color: var(--text-dim); font-family: var(--font); font-size: 11px; cursor: pointer; }
.lc-btn:active { background: #1a1830; }
.search-bar { margin-bottom: 12px; }
.search-bar input { width: 100%; padding: 10px 12px; border: 2px solid var(--border-dark); border-radius: 4px; background: var(--bg-window); color: var(--text); font-family: var(--font); font-size: 12px; outline: none; }
.search-bar input:focus { border-color: var(--border-inner); }
.search-bar input::placeholder { color: #404060; }
.empty-state { text-align: center; padding: 36px 16px; }
.empty-icon { font-size: 32px; margin-bottom: 8px; }
.empty-text { font-size: 13px; color: var(--text-dim); }
.empty-sub { font-size: 10px; color: #404060; margin-top: 4px; }
.export-bar { display: flex; gap: 6px; padding: 14px 16px; }
.export-btn { flex: 1; padding: 9px; border: 1px solid var(--border-dark); border-radius: 4px; background: var(--bg-window); color: var(--text-dim); font-family: var(--font); font-size: 11px; font-weight: bold; cursor: pointer; }
.export-btn:active { background: #1a1830; }
.overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 100; display: flex; align-items: center; justify-content: center; padding: 20px; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
.overlay.open { opacity: 1; pointer-events: auto; }
.overlay-box { max-width: 320px; width: 100%; text-align: center; }
.overlay-box p { font-size: 13px; color: var(--text); margin-bottom: 16px; line-height: 1.5; }
.overlay-btns { display: flex; gap: 8px; }
.overlay-btns button { flex: 1; padding: 10px; border-radius: 4px; font-family: var(--font); font-size: 12px; font-weight: bold; cursor: pointer; }
.btn-keep { border: 1px solid var(--border-dark); background: transparent; color: var(--text-dim); }
.btn-danger { border: 2px solid var(--red); background: var(--red-glow); color: var(--red); }
.success-box { padding: 20px; }
.success-text { font-size: 14px; color: var(--text); line-height: 1.7; text-align: left; margin-bottom: 14px; }
.success-text .hl { color: var(--text-gold); }
.success-text .gr { color: var(--green); }
.success-quote { font-size: 11px; color: var(--text-dim); font-style: italic; line-height: 1.5; margin-bottom: 14px; text-align: left; border-left: 2px solid var(--border-dark); padding-left: 10px; }
.btn-primary { width: 100%; padding: 12px; border: 2px solid var(--border-outer); border-radius: 4px; background: linear-gradient(180deg, #2a2050, #1a1030); color: var(--text-gold); font-family: var(--font); font-size: 13px; font-weight: bold; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; }
.toast { position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%) translateY(16px); background: var(--bg-window); border: 2px solid var(--border-outer); color: var(--text-gold); padding: 8px 18px; border-radius: 4px; font-family: var(--font); font-size: 13px; font-weight: bold; z-index: 999; opacity: 0; transition: all 0.3s; pointer-events: none; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
@keyframes fadeUp { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
.log-card { animation: fadeUp 0.25s ease both; }
</style>
</head>
<body>
<div class="slime-wrap" onclick="spawnCreature()">
  <div class="slime-container" id="creatureWrap"></div>
  <div class="creature-name" id="creatureName"></div>
</div>
<div class="header"><h1>Adventure Log</h1><div class="sub" id="dateText"></div></div>
<div class="stats">
  <div class="stat-card"><div class="stat-val" id="statEntries">0</div><div class="stat-label">Entries</div></div>
  <div class="stat-card"><div class="stat-val" id="statStreak">0</div><div class="stat-label">Day Streak</div></div>
  <div class="stat-card"><div class="stat-val" id="statWords">0</div><div class="stat-label">Words</div></div>
</div>
<div class="wisdom-box dq-window" onclick="newWisdom()">
  <div class="wisdom-label">📜 Words of Wisdom</div>
  <div class="wisdom-text" id="wisdomText"></div>
  <div class="wisdom-source" id="wisdomSource"></div>
  <div class="wisdom-refresh">Tap for more wisdom</div>
</div>
<div class="nav">
  <button class="nav-btn active" id="navWrite" onclick="showView('write')">Write</button>
  <button class="nav-btn" id="navLog" onclick="showView('log')">Log <span class="nav-cnt" id="entryCount">0</span></button>
</div>
<div class="section" id="writeView">
  <div class="dq-window" style="margin-bottom:14px">
    <div class="field" style="margin-bottom:0">
      <div class="label">Thy Thoughts</div>
      <textarea id="journalText" rows="10" placeholder="Write freely, hero. What weighs on thy mind? What happened today? What art thou grateful for? This is thy space."></textarea>
    </div>
  </div>
  <button class="submit-btn" id="submitBtn" onclick="handleSubmit()">Record in the Adventure Log</button>
  <button class="cancel-btn" id="cancelBtn" onclick="cancelEdit()">Cancel Edit</button>
</div>
<div class="section hidden" id="logView">
  <div class="search-bar"><input type="text" id="searchInput" placeholder="Search thy adventure log..." oninput="renderLog()"></div>
  <div id="logList"></div>
</div>
<div class="export-bar">
  <button class="export-btn" onclick="exportJSON()">Export JSON</button>
  <button class="export-btn" onclick="exportTXT()">Export Text</button>
  <button class="export-btn" onclick="document.getElementById('importFile').click()">Import</button>
  <input type="file" id="importFile" accept=".json" style="display:none" onchange="importData(event)">
</div>
<div class="overlay" id="successOverlay"><div class="overlay-box dq-window success-box">
  <div class="success-text" id="successText"></div>
  <div class="success-quote" id="successQuote"></div>
  <button class="btn-primary" onclick="closeSuccess()">Continue</button>
</div></div>
<div class="overlay" id="delOverlay"><div class="overlay-box dq-window">
  <p>Erase this page from the adventure log?</p>
  <div class="overlay-btns"><button class="btn-keep" onclick="closeDelete()">Nay</button><button class="btn-danger" id="delConfirmBtn">Aye</button></div>
</div></div>
<div class="toast" id="toast"></div>
